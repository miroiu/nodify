<Window x:Class="Nodify.Workflow.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Nodify.Workflow"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:nodify="https://miroiu.github.io/nodify"
        xmlns:shell="clr-namespace:Nodify.Workflow.Shell"
        xmlns:shared="clr-namespace:Nodify;assembly=Nodify.Shared"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        Title="{Binding Title}"
        Height="720"
        Width="1280">

    <Window.DataContext>
        <shell:ApplicationViewModel />
    </Window.DataContext>

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Designer/WorkflowDataTemplates.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32"
                      GlassFrameThickness="-1"
                      NonClientFrameEdges="Right,Bottom,Left"
                      UseAeroCaptionButtons="True" />
    </WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <shell:TitleBar Grid.Row="0" />

        <Grid Margin="12"
              Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="{Binding SelectedWorkflow.Value, Converter={shared:NullToGridLengthConverter NotNullValue=2*}}" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <shell:WorkflowsPanel Grid.Column="0"
                                  Margin="0 0 8 0" />

            <Border Grid.Column="1"
                    Visibility="{Binding SelectedWorkflow.Value, Converter={shared:NullToVisibilityConverter}}"
                    CornerRadius="{StaticResource ControlCornerRadius}"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">

                <ContentControl Content="{Binding SelectedWorkflow.Value}" />
            </Border>

            <GridSplitter Grid.Column="2"
                          Visibility="{Binding SelectedWorkflow.Value, Converter={shared:NullToVisibilityConverter}}" />

            <Border Grid.Column="3"
                    CornerRadius="{StaticResource ControlCornerRadius}"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
                <ContentControl Content="{Binding MainWorkflow.Value}" />
            </Border>

        </Grid>
    </Grid>
</Window>
