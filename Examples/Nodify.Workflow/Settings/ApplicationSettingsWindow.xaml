<Window x:Class="Nodify.Workflow.Settings.ApplicationSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Nodify.Workflow.Settings"
        xmlns:nav="clr-namespace:Nodify.Workflow.Navigation"
        xmlns:ic="clr-namespace:FluentIcons.Wpf;assembly=FluentIcons.Wpf"
        d:DataContext="{d:DesignInstance local:ApplicationSettingsViewModel, IsDesignTimeCreatable=True}"
        WindowStyle="ToolWindow"
        mc:Ignorable="d"
        Title="Application Settings"
        BorderThickness="8"
        WindowStartupLocation="CenterScreen"
        Height="600"
        Width="960">

    <Window.Resources>
        <ResourceDictionary Source="/Settings/ApplicationSettingsDataTemplates.xaml" />
    </Window.Resources>

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32"
                      GlassFrameThickness="-1"
                      NonClientFrameEdges="Right,Bottom,Left"
                      UseAeroCaptionButtons="True" />
    </WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0"
                Grid.ColumnSpan="2"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch">
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center">
                <ContentControl Content="{Binding NavigateBackCommand}"
                                WindowChrome.IsHitTestVisibleInChrome="True"
                                Margin="0 0 4 0" />

                <TextBlock VerticalAlignment="Center"
                           Style="{DynamicResource BodyStrongTextBlockStyle}"
                           Text="Workflow Designer" />

                <Border Style="{StaticResource SeparatorStyle.Default}"
                        VerticalAlignment="Center"
                        Margin="12 0" />

                <TextBlock Style="{DynamicResource BodyTextBlockStyle}"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           VerticalAlignment="Center"
                           Text="Settings" />

            </StackPanel>
        </Border>

        <ListView Grid.Row="1"
                  ItemsSource="{Binding SettingsList}"
                  SelectedItem="{Binding SelectedCategory.Value, Mode=TwoWay}"
                  SelectionMode="Single"
                  Margin="0 12 16 12">
            <ListView.ItemTemplate>
                <DataTemplate DataType="{x:Type local:SettingsEntryViewModel}">
                    <StackPanel Orientation="Horizontal">
                        <ic:FluentIcon Icon="{Binding Icon.Value}"
                                       VerticalAlignment="Center" />
                        <TextBlock Margin="16 4"
                                   Text="{Binding Name.Value}" />
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <Grid Grid.Row="1"
              Grid.Column="1">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition />
            </Grid.RowDefinitions>

            <ContentControl Content="{Binding Breadcrumbs}"
                            Focusable="False"
                            Grid.Row="0"
                            MaxWidth="900"
                            Margin="0 12 16 16" />

            <ScrollViewer Grid.Row="1"
                          Padding="0 12 16 0">
                <nav:NavigationOutlet NavigationService="{Binding NavigationService}" />
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
