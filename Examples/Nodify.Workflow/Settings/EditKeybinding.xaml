<UserControl x:Class="Nodify.Workflow.Settings.EditKeybinding"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Nodify.Workflow.Settings"
             xmlns:shared="clr-namespace:Nodify;assembly=Nodify.Shared"
             xmlns:ic="clr-namespace:FluentIcons.Wpf;assembly=FluentIcons.Wpf"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800">
    <Button x:Name="EditButton"
            Height="Auto"
            Click="EditButton_Click">
        <Button.Style>
            <Style TargetType="Button"
                   BasedOn="{StaticResource ButtonStyle.Borderless}">
                <Setter Property="Padding"
                        Value="4" />
                <Setter Property="BorderThickness"
                        Value="2" />
            </Style>
        </Button.Style>
        <StackPanel Orientation="Horizontal">
            <Border Background="{DynamicResource AccentFillColorDefaultBrush}"
                    CornerRadius="{DynamicResource ControlCornerRadius}"
                    Padding="6"
                    Margin="0 0 8 0">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ComboTriggerKey.Value}"
                                         Value="{x:Static Key.None}">
                                <Setter Property="Visibility"
                                        Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="{Binding ComboTriggerKey.Value, Converter={shared:ToStringConverter}}"
                           Foreground="{DynamicResource TextOnAccentFillColorPrimaryBrush}"
                           Style="{StaticResource BodyStrongTextBlockStyle}">
                </TextBlock>
            </Border>
            <Border Background="{DynamicResource AccentFillColorDefaultBrush}"
                    CornerRadius="{DynamicResource ControlCornerRadius}"
                    Padding="6"
                    Margin="0 0 8 0">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Modifier.Value}"
                                         Value="{x:Static ModifierKeys.None}">
                                <Setter Property="Visibility"
                                        Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="{Binding Modifier.Value, Converter={shared:ToStringConverter}}"
                           Foreground="{DynamicResource TextOnAccentFillColorPrimaryBrush}"
                           Style="{StaticResource BodyStrongTextBlockStyle}">
                </TextBlock>
            </Border>
            <Border Background="{DynamicResource AccentFillColorDefaultBrush}"
                    CornerRadius="{DynamicResource ControlCornerRadius}"
                    Padding="6"
                    Margin="0 0 8 0">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Key.Value}"
                                         Value="{x:Static Key.None}">
                                <Setter Property="Visibility"
                                        Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="{Binding Key.Value, Converter={shared:ToStringConverter}}"
                           Foreground="{DynamicResource TextOnAccentFillColorPrimaryBrush}"
                           Style="{StaticResource BodyStrongTextBlockStyle}" />
            </Border>
            <ic:FluentIcon x:Name="EditIcon"
                           IconSize="Size16"
                           FontSize="16"
                           Height="32"
                           Margin="4 0"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                           Icon="Edit"
                           VerticalAlignment="Center" />
        </StackPanel>
    </Button>
</UserControl>
