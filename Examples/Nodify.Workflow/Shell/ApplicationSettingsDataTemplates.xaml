<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:local="clr-namespace:Nodify.Workflow.Shell"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <DataTemplate DataType="{x:Type local:KeybindingsSettingsCategoryViewModel}">
        <Grid Grid.Row="1"
              Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="{Binding Name.Value}"
                       Style="{DynamicResource TitleTextBlockStyle}"
                       MaxWidth="900"
                       Margin="0 12 16 24" />

            <ScrollViewer Grid.Row="1"
                          Padding="0 12 16 0">
                <ItemsControl ItemsSource="{Binding Categories}"
                              MaxWidth="900">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type local:KeybindingCategoryViewModel}">
                            <local:KeybindingsCategory Icon="{Binding Icon.Value}"
                                                       Label="{Binding Name.Value}"
                                                       Description="{Binding Description.Value}"
                                                       Margin="0 0 0 8" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </DataTemplate>

    <DataTemplate DataType="{x:Type local:SettingsCategoryViewModel}">
        <Grid Grid.Row="1"
              Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="{Binding Name.Value}"
                       Style="{DynamicResource TitleTextBlockStyle}"
                       MaxWidth="900"
                       Margin="0 12 16 24" />

            <ScrollViewer Grid.Row="1"
                          Padding="0 12 16 0">
                <StackPanel MaxWidth="900"></StackPanel>
            </ScrollViewer>
        </Grid>
    </DataTemplate>

</ResourceDictionary>