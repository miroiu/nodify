<Window x:Class="Nodify.Workflow.Shell.ApplicationSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Nodify.Workflow.Shell"
        xmlns:ic="clr-namespace:FluentIcons.Wpf;assembly=FluentIcons.Wpf"
        d:DataContext="{d:DesignInstance local:ApplicationSettingsViewModel, IsDesignTimeCreatable=True}"
        WindowStyle="ToolWindow"
        mc:Ignorable="d"
        Title="Application Settings"
        BorderThickness="8"
        WindowStartupLocation="CenterScreen"
        Height="600"
        Width="800">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32"
                      GlassFrameThickness="-1"
                      NonClientFrameEdges="Right,Bottom,Left"
                      UseAeroCaptionButtons="True" />
    </WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0"
                Grid.ColumnSpan="2"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch">
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center">
                <ic:FluentIcon Icon="Flow"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource AccentFillColorSecondaryBrush}"
                               Margin="16 0 16 0" />

                <TextBlock VerticalAlignment="Center"
                           Style="{DynamicResource BodyStrongTextBlockStyle}"
                           Text="Workflow Designer" />

                <Border Style="{StaticResource SeparatorStyle.Default}"
                        VerticalAlignment="Center"
                        Margin="12 0" />

                <TextBlock Style="{DynamicResource BodyTextBlockStyle}"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           VerticalAlignment="Center"
                           Text="Settings" />

            </StackPanel>
        </Border>

        <ListView Grid.Row="1"
                  SelectionMode="Single"
                  Margin="0 12 16 12">
            <ListViewItem>
                <StackPanel Orientation="Horizontal">
                    <ic:FluentIcon Icon="Settings"
                                   VerticalAlignment="Center" />
                    <TextBlock Margin="16 4"
                               Text="General" />
                </StackPanel>
            </ListViewItem>
            <ListViewItem IsSelected="True">
                <StackPanel Orientation="Horizontal">
                    <ic:FluentIcon Icon="Keyboard"
                                   VerticalAlignment="Center" />
                    <TextBlock Margin="16 4"
                               Text="Keybindings" />
                </StackPanel>
            </ListViewItem>
            <ListViewItem>
                <StackPanel Orientation="Horizontal">
                    <ic:FluentIcon Icon="Color"
                                   VerticalAlignment="Center" />
                    <TextBlock Margin="16 4"
                               Text="Appearance" />
                </StackPanel>
            </ListViewItem>
            <ListViewItem>
                <StackPanel Orientation="Horizontal">
                    <ic:FluentIcon Icon="Info"
                                   VerticalAlignment="Center" />
                    <TextBlock Margin="16 4"
                               Text="About" />
                </StackPanel>
            </ListViewItem>
        </ListView>

        <StackPanel Grid.Row="1"
                    Grid.Column="1"
                    Margin="0 12 16 12">
            <TextBlock Text="Keybindings"
                       Style="{DynamicResource TitleTextBlockStyle}"
                       Margin="0 0 0 36" />

            <TextBlock Text="Editor"
                       Style="{DynamicResource SubtitleTextBlockStyle}" />

            <Border>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                </Grid>
            </Border>
        </StackPanel>
    </Grid>
</Window>
