<UserControl x:Class="Nodify.Workflow.Shell.TitleBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Nodify.Workflow.Shell"
             xmlns:ic="clr-namespace:FluentIcons.Wpf;assembly=FluentIcons.Wpf"
             xmlns:ctzex="urn:controlzex"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:shared="clr-namespace:Nodify;assembly=Nodify.Shared"
             d:DataContext="{d:DesignInstance local:ApplicationViewModel, IsDesignTimeCreatable=True}"
             mc:Ignorable="d"
             d:DesignHeight="50"
             d:DesignWidth="1200">

    <UserControl.Resources>
        <Style x:Key="BreadcrumbStyle"
               BasedOn="{StaticResource ButtonStyle.Borderless}"
               TargetType="Button">
            <Setter Property="Height"
                    Value="26" />
            <Setter Property="Padding"
                    Value="8 4" />
            <Setter Property="VerticalAlignment"
                    Value="Center" />
            <Setter Property="HorizontalAlignment"
                    Value="Center" />
            <Setter Property="HorizontalContentAlignment"
                    Value="Center" />
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome"
                    Value="True" />
        </Style>
    </UserControl.Resources>

    <Grid HorizontalAlignment="Stretch"
          VerticalAlignment="Stretch"
          Height="32"
          Margin="0 0 140 0"
          Background="Transparent"
          d:Background="White">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0"
                    Orientation="Horizontal"
                    VerticalAlignment="Center">
            <ic:FluentIcon Icon="Flow"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource AccentFillColorSecondaryBrush}"
                           Margin="10 0 8 0" />

            <TextBlock VerticalAlignment="Center"
                       Style="{DynamicResource BodyStrongTextBlockStyle}"
                       Text="{Binding Title}"
                       d:Text="Workflow Designer" />

            <Border Style="{StaticResource SeparatorStyle.Default}"
                    VerticalAlignment="Center"
                    Margin="12 2 4 0" />

            <Button Style="{StaticResource BreadcrumbStyle}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Style="{DynamicResource BodyTextBlockStyle}"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               VerticalAlignment="Center"
                               Text="{Binding MainWorkflow.Value.Name.Value}"
                               d:Text="Workflow Name" />

                    <ic:FluentIcon Icon="ChevronRight"
                                   IconSize="Size12"
                                   FontSize="12"
                                   IsHitTestVisible="False"
                                   VerticalAlignment="Center"
                                   Margin="8 4 0 2"
                                   Visibility="{Binding SelectedWorkflow.Value, Converter={shared:NullToVisibilityConverter}}"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Button>

            <Button Style="{StaticResource BreadcrumbStyle}"
                    Visibility="{Binding SelectedWorkflow.Value, Converter={shared:NullToVisibilityConverter}}">
                <TextBlock Style="{DynamicResource BodyTextBlockStyle}"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           VerticalAlignment="Center"
                           Text="{Binding SelectedWorkflow.Value.Name.Value}"
                           d:Text="Sub Workflow Name" />
            </Button>
        </StackPanel>


        <StackPanel Grid.Column="2"
                    Orientation="Horizontal"
                    VerticalAlignment="Center">

            <ContentControl Content="{Binding RunWorkflowCommand}"
                            Focusable="False"
                            VerticalAlignment="Center"
                            WindowChrome.IsHitTestVisibleInChrome="True" />
            <ContentControl Content="{Binding SaveChangesCommand}"
                            Focusable="False"
                            WindowChrome.IsHitTestVisibleInChrome="True"
                            VerticalAlignment="Center" />
            <ContentControl Content="{Binding ToggleZenModeCommand}"
                            Focusable="False"
                            WindowChrome.IsHitTestVisibleInChrome="True"
                            VerticalAlignment="Center" />

            <Border Style="{StaticResource SeparatorStyle.Default}" />

            <ContentControl Content="{Binding OpenSettingsCommand}"
                            Focusable="False"
                            WindowChrome.IsHitTestVisibleInChrome="True"
                            VerticalAlignment="Center" />

            <Border Style="{StaticResource SeparatorStyle.Default}" />
        </StackPanel>

    </Grid>
</UserControl>
